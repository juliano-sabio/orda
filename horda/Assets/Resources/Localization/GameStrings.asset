    - SUKSES!
  - key: event.failure
    translations:
    - X FALHOU!
    - X FAILED!
    - "\xA1FALL\xD3!"
    - FEHLGESCHLAGEN!
    - "\xC9CHEC!"
    - FALLITO!
    - "\u041F\u0420\u041E\u0412\u0410\u041B!"
    - NIEPOWODZENIE!
