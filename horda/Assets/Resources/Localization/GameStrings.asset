  - key: tutorial.survive.title
    translations:
    - SOBREVIVA!
    - SURVIVE!
    - "\xA1SOBREVIVE!"
    - "\xDCBERLEBE!"
    - SURVIVEZ !
    - SOPRAVVIVI!
